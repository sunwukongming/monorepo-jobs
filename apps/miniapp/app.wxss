page {
    --tabs-bottom-bar-color: #5ED5C8;
    --theme: #5ED5C8;
}
.container {
  height: 100%;
  width: 100%;
  /*兼容 IOS<11.2*/
  /* padding-bottom: constant(safe-area-inset-bottom);  */
  /*兼容 IOS>11.2*/
  /* padding-bottom: env(safe-area-inset-bottom);  */
} 
.icon {
    display: flex;
    justify-content: center;
    align-items: center;
}
image {
    width: 100%;
    height: 100%;
}

.btn-save {
    width: 100%;
    height: 90rpx;
    background-color: #5ED5C8;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 34rpx;
    color: #fff;
    border-radius: 56rpx;
}

.btn-save::after {
    border: none;
}

.no-btn {
    background-color: transparent;
}
.no-btn::after {
    border: none;
}

.van-switch {
    font-size: 40rpx !important;
}

.full {
    width: 100%;
    height: 100%;
}

.placeholder {
    color: #999;
    font-size: 28rpx;
    font-weight: 400;
    line-height: 40rpx;
}