.modal-container {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 101;
}

.modal-container .backdrop {
    position: fixed;
    width: 100%;
    height: 100%;
    z-index: 1050;
    background-color: #000;
    opacity: .5;
}

.modal {
    position: relative;
    z-index: 2020;
    background-color: #fff;
    border-radius: 40rpx;
    width: 640rpx;
}

.modal-header {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100rpx;
    font-size: 36rpx;
}

.modal-body {
    padding: 0 50rpx;
}

.modal-footer {
    position: relative;
    bottom: -102rpx;
    display: flex;
    justify-content: center;
}

.modal-footer .close {
    width: 60rpx;
    height: 60rpx;
}