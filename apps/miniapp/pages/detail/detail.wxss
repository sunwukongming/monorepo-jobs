.container {
    background-color: #F6F7FA;
    padding-bottom: calc(130rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

.wrapper {
    padding: 32rpx;
    /* background-color: #fff; */
}

.title {
    display: flex;
    align-items: center;
    font-size: 42rpx;
    font-weight: bold;
    color: #181818;
    margin-bottom: 16rpx;
}

.title .icon {
    width: 40rpx;
    height: 40rpx;
    margin-left: 10rpx;
}

.desc {
    font-size: 30rpx;
    font-weight: 400;
    color: #595959;
    line-height: 40rpx;
}

.contact {
    color: #2D62FF;
}

.tags {
    display: flex;
    align-items: center;
}

.tag-item {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 220rpx;
    height: 130rpx;
    border-radius: 10rpx;
    background-color: #FAFBFF;
}

.tag-item .header {
    display: flex;
    align-items: center;
}

.tag-item .icon {
    width: 30rpx;
    height: 30rpx;
    margin-right: 6rpx;
}

.tag-item .label {
    font-size: 28rpx;
    color: #181818;
    font-weight: 400;
}

.tag-item .footer {
    font-size: 30rpx;
    color: #2AAFA1;
    font-weight: 600;
    margin-top: 12rpx;
}

.tag-item+.tag-item {
    margin-left: 18rpx;
}

.sub-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #181818;
}

.sub-title+.desc {
    line-height: 50rpx;
}

.relative-wrapper,
.wrapper+.wrapper {
    margin-top: 30rpx;
}

.relative-text {
    padding-top: 88rpx;
    background-color: #fff;
    padding-top: 36rpx;
    padding-left: 32rpx;
    color: #7B7B7B;
}

.list-item {
    padding: 32rpx;
    background-color: #fff;
}

.item-title {
    height: 50rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14rpx;
}

.item-title .left {
    display: flex;
    align-items: center;
}

.item-title .left .text {
    font-size: 36rpx;
    color: #181818;
    line-height: 50rpx;
}

.item-title .left .top {
    width: 40rpx;
    height: 40rpx;
    margin-left: 4px;
}

.item-title .right {
    font-size: 24rpx;
    font-weight: 400;
    color: #acacac;
}

.item-desc {
    font-size: 26rpx;
    font-weight: 400;
    color: #7B7B7B;
    line-height: 36rpx;
    margin-bottom: 10rpx;
}

.item-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.item-footer .location {
    width: 40rpx;
    height: 40rpx;
}

.item-footer .left {
    color: #acacac;
    font-size: 28rpx;
    position: relative;
    left: -10rpx;
}

.item-footer .left .text+.text {
    margin-left: 10rpx;
}

.item-footer .right {
    font-size: 30rpx;
    color: #248379;
    font-weight: bold;
}

.item-footer .right .symbol {
    margin-left: 10rpx;
    margin-right: 10rpx;
}

.item-footer .left,
.item-footer .right {
    display: flex;
    align-items: center;
}

.list-wrapper {
    background-color: #F6F7FA;
}

.list-item+.list-item {
    margin-top: 10rpx;
}

.action {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
}

.action-content {
    display: flex;
    align-items: center;
    background-color: #fff;
    border-top: 1px solid #F6F7FA;
    padding-bottom: constant(safe-area-inset-bottom);
    /*兼容 IOS<11.2*/
    padding-bottom: env(safe-area-inset-bottom);
    /*兼容 IOS>11.2*/
    position: relative;
}

.phone-btn {
    position: absolute;
    width: 630rpx;
    height: 100%;
    top: 0;
    right: 0;
    z-index: 999;
}

.action .group {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #7B7B7B;
    font-size: 24rpx;
    height: 92rpx;
}

.group .icon {
    width: 60rpx;
    height: 60rpx;
    flex-shrink: 0;
}

.no-btn {
    margin: 0;
    padding: 0;
    background-color: inherit;
    position: static;
    flex-shrink: 0;
    line-height: normal;
}

.no-btn:after {
    content: none;
}

/* 去掉边框 */
.no-btn::after {
    border: none;
}

.action .left {
    width: 38%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-right: 24rpx;
    padding-left: 24rpx;
}

.action .right {
    width: 62%;
    padding: 10rpx 24rpx 10rpx 0;
    display: flex;
    gap: 24rpx;
}

.btn-save {
    width: auto;
}

.modal-container {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    justify-content: center;
    align-items: center;
}

.modal-container .backdrop {
    position: fixed;
    width: 100%;
    height: 100%;
    z-index: 1050;
    background-color: #000;
    opacity: .5;
}

.modal {
    position: relative;
    z-index: 2020;
    background-color: #fff;
    border-radius: 40rpx;
    width: 640rpx;
}

.modal-header {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100rpx;
    font-size: 36rpx;
}

.modal-body {
    padding: 0 50rpx;
}

.modal-footer {
    position: relative;
    bottom: -102rpx;
    display: flex;
    justify-content: center;
}

.modal-footer .close {
    width: 60rpx;
    height: 60rpx;
}

.menu-btn {
    width: 100% !important;
    height: 152rpx;
    display: flex;
    align-items: center;
    background-color: #fff;
    font-size: 30rpx;
    color: #181818;
    text-align: left;
    line-height: normal;
}

.menu-btn::after {
    border: none;
}

.menu-btn .icon {
    width: 100rpx;
    height: 100rpx;
    margin-right: 34rpx;
    flex-shrink: 0;
}

.menu-btn:nth-child(2) {
    border-top: 1px solid #E1E2E6;
    border-bottom: 1px solid #E1E2E6;
}

.share-tips {
    font-size: 32rpx;
    color: #000;
    margin-bottom: 32rpx;
}

.btn-login {
    background-color: #5ED5C8;
    color: white;
    height: 90rpx;
    font-size: 34rpx;
    border-radius: 50rpx;
}

.link {
    color: #1989fa;
}

.modal-content {
    max-height: 750rpx;
}

.company-remark {
    padding: 0 32rpx 32rpx;
    color: #7B7B7B;
    font-size: 28rpx;
    line-height: 50rpx;
}

.sentence {
    min-height: 1px;
}

.sentence.blank {
    margin-top: 14rpx;
    margin-bottom: 14rpx;
}

.help {
    width: 30rpx;
    height: 30rpx;
    position: absolute;
    right: 0;
    top: 0;
}

.company-title {
    display: flex;
    justify-content: center;
    align-items: center;
    color: #333;
    font-size: 28rpx;
    line-height: 50rpx;
    font-weight: 600;
}

.van-dialog__header {
    height: 80rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 0 !important;
    border-bottom: 1px solid #E4E5E8;
}

.panel {
    background-color: #fff;
    border-radius: 20rpx;
    padding: 32rpx;
    margin-bottom: 10rpx;
}

.dialog-content {
    padding: 32rpx;
    font-size: 28rpx;
    line-height: 38rpx;
}

.btn-update {
    background-color: #1989fa;
    border-radius: 8rpx;
    margin-left: 4rpx;
    color: #fff;
    font-size: 24rpx;
    line-height: 30rpx;
    padding: 4rpx 12rpx;
}

.modal-action {
    margin-bottom: 32rpx;
    display: flex;
}

.modal-btn {
    width: 50%;
    height: 64rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.modal-btn.confirm {
    color: #1989fa;
}

.resume {
    position: relative;
}

.resume .modal-footer {
    position: absolute;
    left: calc(50% - 32rpx);
}

.recommend-content {
    padding: 24rpx;
    box-sizing: border-box;
    color: #666;
    font-size: 32rpx;
    line-height: 40rpx;
}

.recommend-content .text {
    margin-bottom: 24rpx;
}

.van-dialog__header {
    font-size: 34rpx;
    font-weight: bold !important;
}

.btn-primary {
    color: var(--theme);
}

.login-container {
    padding: 54rpx 32rpx 64rpx;
}

.login-tips {
    color: #333;
    font-weight: bold;
    font-size: 50rpx;
    margin-bottom: 54rpx;
}

.tips-title {
    line-height: 70rpx;
}

.tips-desc {
    font-size: 30rpx;
    font-weight: 400;
    line-height: 40rpx;
    color: #FF952D;
    margin-top: 12rpx;
}

.login-action {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.login-btn {
    width: 100%;
    height: 90rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    margin-bottom: 32rpx;
    border-radius: 50rpx;
    background-color: var(--theme);
    color: #fff;
}

.login-btn::after {
    border: 0;
}

.login-cancel {
    font-size: 30rpx;
    font-weight: 400;
    color: #80808B;
}

.tips-title {
    display: flex;
    justify-content: space-between;
}

.open-privacy {
    font-size: 24rpx;
    color: #279EFF;
}

.callout {
    width: 180rpx;
    height: 60rpx;
    position: absolute;
    top: -64rpx;
    margin-bottom: env(safe-area-inset-bottom);
    margin-bottom: constant(safe-area-inset-bottom);
    right: 30rpx;
    background-color: #fbc174;
    color: #fff;
    font-size: 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 12rpx;
    animation: jump .5s ease-in-out infinite alternate;
}

.callout::after {
    position: absolute;
    bottom: -12rpx;
    content: '';
    border-right: 12rpx solid transparent;
    border-left: 12rpx solid transparent;
    border-top: 12rpx solid #fbc174;
}

@keyframes jump {
    from {
        top: -64rpx;
    }
    to {
        top: -80rpx;
    }
}

.btn-container {
    margin-top: 20rpx;
    display: flex;
    justify-content: center;
}

.btn-primary {
    width: 160rpx;
    height: 50rpx;
    background-color: #5ED5C8;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24rpx;
    color: #fff;
    border-radius: 10rpx;
}

.link {
    width: 32rpx;
    height: 32rpx;
}

.van-share-sheet__header {
    padding: 0 !important;
}

.van-share-sheet__title {
    font-size: 36rpx !important;
    font-weight: bold !important;
    color: #fff !important;
    margin-top: 0 !important;
    background-color: var(--theme);
    padding: 24rpx 32rpx;
}

.van-share-sheet__description {
    text-align: left;
    font-size: 28rpx !important;
    line-height: 36rpx !important;
    color: #646566 !important;
    padding: 0rpx 24rpx;
}

.van-share-sheet__options {
    overflow-x: hidden !important;
    overflow-y: hidden !important;
    gap: 16rpx;
    padding: 16rpx !important;
}

.van-share-sheet__button {
    width: 160rpx;
    line-height: 32rpx !important;
}

.van-share-sheet__name {
    font-size: 28rpx !important;
}

.van-overlay {
    background-color:var(--overlay-background-color,rgba(0,0,0,.1));
    opacity: 1;
}

.menu-container {
    position: fixed;
    bottom: 320rpx;
    right: 32rpx;
}

.menu {
    background-color: var(--theme);
    width: 88rpx;
    height: 88rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
}

.menu-tips {
    width: 330rpx;
    height: 88rpx;
    position: absolute;
    bottom: 0rpx;
    right: 100rpx;
    background-color: var(--theme);
    color: #fff;
    font-size: 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 12rpx;
}

.menu-tips::after {
    position: absolute;
    right: -12rpx;
    content: '';
    border-left: 12rpx solid var(--theme);
    border-top: 12rpx solid transparent;
    border-bottom: 12rpx solid transparent;
}

.a-avatar {
    width: 132rpx;
    height: 132rpx;
    background: linear-gradient( 166deg, #07DEC6 0%, #42BAEE 100%);
    border-radius: 24rpx;
    border: 1rpx solid #E1E2E3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size: 34rpx;
    color: #FFFFFF;
    line-height: 48rpx;
    flex-shrink: 0;
}

.a-title,
.b-title {
    font-weight: bold;
    font-size: 30rpx;
    color: #181818;
    line-height: 42rpx;
}

.b-tags {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 16rpx;
    padding: 0 24rpx;
}

.b-tag {
    background-color: #F6F7FA;
    color: #666;
    padding: 6rpx 16rpx;
    font-size: 22rpx;
    font-weight: 400;
    margin-right: 16rpx;
    margin-bottom: 16rpx;
}

.b-tag:last-child {
    margin-right: 0;
}

.a-desc,
.b-desc {
    margin-top: 16rpx;
    font-weight: 400;
    font-size: 24rpx;
    color: #7B7B7B;
    line-height: 33rpx;
}

.b-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 108rpx;
    background: #FFF9ED;
    border-radius: 0rpx 0rpx 20rpx 20rpx;
    font-size: 26rpx;
    color: #CD833F;
    line-height: 37rpx;
}