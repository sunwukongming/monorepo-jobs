.container {
    background-color: #fff;
    min-height: 100vh;
}

/* 轮播图 */
.swiper-container {
    margin-top: 30rpx;
    bottom: 8rpx;
    position: relative;
}

.swiper-wrapper {
    width: 100%;
    height: 280rpx;
}

.swiper-item {
    width: 650rpx !important;
    border-radius: 20rpx;
    display: flex;
    justify-content: center;
}

.swiper-image-container {
    width: 100%;
    height: 100%;
    padding-left: 18rpx;
    padding-right: 18rpx;
}

.swiper-image {
    border-radius: 20rpx;
}

.swiper-dots {
    position: relative;
    bottom: -28rpx;
    margin-bottom: 28rpx;
    display: flex;
    justify-content: center;
}

.dot-item {
    margin: 0 14rpx;
    width: 16rpx;
    height: 16rpx;
    background-color: #D1D1D1;
    border-radius: 8rpx;
    transition: all .5s;
}

.dot-item.active {
    background: #5ED5C8;
}

/* 搜索框 */
.search-wrapper {
    padding: 16rpx 32rpx;
    background-color: #fff;
}

.search-container {
    width: 686rpx;
    height: 80rpx;
    background-color: #f6f7fa;
    border-radius: 10rpx;
    display: flex;
    align-items: center;
}

.search-icon {
    width: 40rpx;
    height: 40rpx;
    margin-left: 28rpx;
    margin-right: 48rpx;
}

.search-input {
    width: 482rpx;
    font-size: 28rpx;
    font-weight: 400;
    color: #B5B5B5;
}

.close-icon {
    width: 32rpx;
    height: 100%;
    padding-left: 28rpx;
    padding-right: 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99;
}

.close-icon > image {
    width: 32rpx;
    height: 32rpx;
}

/* 内容部分 */
.content-container {
    border-top: 1px solid #E4E6EB;
    display: flex;
    overflow: hidden;
}

.category-wrapper {
    width: 150rpx;
    border-right: 1px solid #E4E6EB;
    box-shadow: 10rpx 0 10rpx 0 rgba(242,243,245,0.5);
    z-index: 2;
    height: 100%;
    overflow: hidden;
}

.category {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 20rpx 0 0 0;
}

.category.active .category-title {
    color: #29AFA1;
}

.category-title {
    color: #A0A1A4;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 30rpx;
}

.article-wrapper {
    width: 600rpx;
    background-color: #F6F7FA;
    z-index: 1;
    height: 100%;
    overflow-x: scroll;
}

.article {
    background-color: #fff;
    padding: 32rpx;
}

.article + .article {
    margin-top: 10rpx;
}

.article-title {
    display: flex;
    align-items: center;
    margin-bottom: 10rpx;
}

.article-title .text {
    color: #181818;
    font-size: 32rpx;
    font-weight: 600;
    line-height: 45rpx;
    margin-right: 12rpx;
    display: -webkit-box;
    word-break: break-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-overflow: ellipsis;
}

.article-title .tag {
    flex-shrink: 0;
    width: 60rpx;
    height: 32rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 20rpx;
    font-weight: 400;
    color: #fff;
    background-color: #FF6363;
    border-radius: 12rpx;
}

.article-content {
    color: #7B7B7B;
    font-size: 22rpx;
    line-height: 36rpx;
    font-weight: 400;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    margin-bottom: 14rpx;
}

.article-footer {
    color: #80808B;
    font-size: 22rpx;
    font-weight: 400;
    display: flex;
    gap: 32rpx;
}

.publisher {    
    text-overflow: ellipsis;
    white-space: nowrap;
}
