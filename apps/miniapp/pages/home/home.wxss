.container {
    height: auto;
}

.swiper-container {
    margin-top: 30rpx;
    bottom: 8rpx;
    position: relative;
}

.swiper-wrapper {
    width: 100%;
    height: 280rpx;
}

.swiper-item {
    width: 650rpx !important;
    border-radius: 20rpx;
    display: flex;
    justify-content: center;
}

.swiper-image-container {
    width: 100%;
    height: 100%;
    padding-left: 18rpx;
    padding-right: 18rpx;
}

.swiper-image {
    border-radius: 20rpx;
}

.swiper-dots {
    position: relative;
    bottom: -28rpx;
    margin-bottom: 28rpx;
    display: flex;
    justify-content: center;
}

.dot-item {
    margin: 0 14rpx;
    width: 16rpx;
    height: 16rpx;
    background-color: #D1D1D1;
    border-radius: 8rpx;
    transition: all .5s;
}

.dot-item.active {
    background: #5ED5C8;
}

.userinfo {
    height: 60rpx;
    padding: 0 32rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* margin-bottom: 20rpx; */
    margin-top: 20rpx;
    background-color: #fff;
}

.userinfo .left {
    color: #7B7B7B;
    font-size: 26rpx;
    font-weight: 400;
}

.userinfo .right {
    color: #1989fa;
    font-size: 28rpx;
    display: flex;
    align-items: center;
}

.userinfo .icon {
    margin-left: 12rpx;
    width: 28rpx;
    height: 28rpx;
}

.search-wrapper {
    /* position: sticky; */
    padding: 16rpx 32rpx;
    background-color: #fff;
    z-index: 99;
}

.search-container {
    width: 686rpx;
    height: 80rpx;
    background-color: #f6f7fa;
    border-radius: 10rpx;
    display: flex;
    align-items: center;
}

.search-icon {
    width: 40rpx;
    height: 40rpx;
    margin-left: 28rpx;
    margin-right: 48rpx;
}

.search-input {
    width: 482rpx;
    font-size: 28rpx;
    font-weight: 400;
    color: #B5B5B5;
}

.close-icon {
    width: 32rpx;
    height: 100%;
    padding-left: 28rpx;
    padding-right: 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99;
}

.close-icon > image {
    width: 32rpx;
    height: 32rpx;
}

.list-filter {
    /* position: sticky; */
    display: flex;
    justify-content: flex-start;
    align-items: center;
    border-bottom: 1px solid #f6f7fa;
    background-color: #fff;
    padding: 0 32rpx;
    z-index: 99;
} 

.filter-item {
    height: 80rpx;
    width: 250rpx;
    flex: auto;
    display: flex;
    justify-content: center;
    align-items: center;
}

.filter-text {
    color: #7B7B7B;
    font-size: 30rpx;
    font-weight: 400;
    margin-right: 10rpx;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.filter-icon {
    width: 30rpx;
    height: 30rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.list-wrapper {
    background-color: #F6F7FA;
}

.list-item {
    position: relative;
    padding: 32rpx;
    background-color: #fff;
}

.list-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 0 32rpx;
    display: flex;
    justify-content: space-between;
}

.list-item .tag {
    font-size: 22rpx;
    line-height: 30rpx;
    height: 30rpx;
    padding: 0rpx 16rpx;
    background-color: var(--theme);
    color: #fff;
    border-radius: 20rpx;
}

.tag.active {
    background-color: #FFBB5F;
}

.item-content {
    width: 100%;
}

.item-title {
    height: 50rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14rpx;
    font-weight: 600;
    width: 100%;
}

.item-title .left {
    display: flex;
    align-items: center;
}

.item-title .left .text {
    font-size: 36rpx;
    color: #181818;
    line-height: 50rpx;
    max-width: 520rpx;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.item-title .left .top {
    width: 40rpx;
    height: 40rpx;
    margin-left: 4px;
}

.item-title .right {
    font-size: 24rpx;
    font-weight: 400;
    color: #acacac;
}

.item-desc {
    font-size: 26rpx;
    font-weight: 400;
    color: #7B7B7B;
    line-height: 36rpx;
    margin-bottom: 10rpx;
    display: -webkit-box;
    overflow: hidden;
    text-overflow: ellipsis;
    word-wrap: break-word;
    white-space: normal !important;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
}

.item-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.item-footer .location {
    width: 40rpx;
    height: 40rpx;
}

.item-footer .left {
    color: #acacac;
    font-size: 28rpx;
    position: relative;
    left: -10rpx;
}

.item-footer .left .text + .text {
    margin-left: 10rpx;
}

.item-footer .right {
    font-size: 30rpx;
    color: #248379;
    font-weight: bold;
}

.item-footer .right .symbol {
    margin-left: 10rpx;
    margin-right: 10rpx;
}

.item-footer .left,
.item-footer .right {
    display: flex;
    align-items: center;
}

.list-item + .list-item {
    margin-top: 10rpx;
}

.history-container {
    margin-top: 16rpx;
    margin-bottom: 16rpx;
}

.history-title {
    font-size: 26rpx;
    color: #666;
}

.history {
    display: flex;
    flex-wrap: wrap;
    gap: 12rpx;
    margin-top: 16rpx;
}

.history-word {
    height: 36rpx;
    line-height: 36rpx;
    background-color: #909090;
    color: white;
    font-size: 24rpx;
    padding: 0 12rpx;
    border-radius: 12rpx;
}

.callout {
    width: 180rpx;
    height: 60rpx;
    position: fixed;
    bottom: 12rpx;
    left: calc(25% + (25% - 180rpx) / 2);
    background-color: #fbc174;
    color: #fff;
    font-size: 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 12rpx;
    animation: jump .5s ease-in-out infinite alternate;
}

.callout::after {
    position: absolute;
    bottom: -12rpx;
    content: '';
	border-right: 12rpx solid transparent;
	border-left: 12rpx solid transparent;
	border-top: 12rpx solid #fbc174;
}


.login-container {
    padding: 54rpx 32rpx 64rpx;
}

.login-tips {
    color: #333;
    font-weight: bold;
    font-size: 50rpx;
    margin-bottom: 54rpx;
}

.tips-title {
    line-height: 70rpx;
}

.tips-desc {
    font-size: 30rpx;
    font-weight: 400;
    line-height: 40rpx;
    color: #FF952D;
    margin-top: 12rpx;
}

.login-action {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.login-btn {
    width: 100%;
    height: 90rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    margin-bottom: 32rpx;
    border-radius: 64rpx;
    background-color: var(--theme);
    color: #fff;
}

.login-btn::after {
    border: 0;
}

.login-cancel {
    font-size: 30rpx;
    font-weight: 400;
    color: #80808B;
}

.tips-title {
    display: flex;
    justify-content: space-between;
}

.open-privacy {
    font-size: 24rpx;
    color: #279EFF;
}

@keyframes jump {
    from {
        bottom: 32rpx;
    }
    to {
        bottom: 12rpx;
    }
}

.item-container {
    display: flex;
    gap: 16rpx;
}

.item-tags {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 8rpx;
}

.item-tag {
    background-color: #F6F7FA;
    color: #666;
    padding: 6rpx 16rpx;
    font-size: 22rpx;
    font-weight: 400;
    margin-right: 32rpx;
    margin-bottom: 16rpx;
}

.van-tab {
    font-size: 30rpx !important;
}
