.container {
    padding-bottom: calc(130rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

.wrapper {
    padding: 32rpx;
    background-color: #F6F7FA;
}

.panel {
    background-color: #fff;
    border-radius: 20rpx;
    padding: 32rpx;
    margin-bottom: 10rpx;
}

.panel-title {
    font-size: 32rpx;
    font-weight: bold;
    color: var(--theme);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.panel-title .title-time {
    font-size: 30rpx;
    color: #999;
    font-weight: 400;
}

.panel .job {
    font-size: 40rpx;
    color: #181818;
    line-height: 56rpx;
    margin-top: 10rpx;
    font-weight: 600;
}

.job-info {
    margin-top: 24rpx;
}

.info-group {
    display: flex;
    align-items: flex-start;
    line-height: 40rpx;
}

.info-group .symbol {
    width: 8rpx;
    height: 8rpx;
    background-color: #D8D8D8;
    margin-right: 16rpx;
}

.info-group .label {
    color: #80808B;
    font-size: 28rpx;
    width: 150rpx;
    flex-shrink: 0;
}

.info-group .value {
    color: #181818;
    font-size: 28rpx;
}

.text {
    color: #181818;
    font-size: 28rpx;
    line-height: 50rpx;
    margin-top: 24rpx;
}

.second {
    margin-top: 24rpx;
}

.wrapper-title {
    margin-top: 32rpx;
    margin-bottom: 16rpx;
}

.job-user {
    font-weight: 400;
    font-size: 24rpx;
    color: #80808B;
    line-height: 40rpx;
    margin-top: 14rpx;
}

.panel-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20rpx;
}

.date {
    font-size: 22rpx;
    font-weight: 400;
    color: #ACACAC;
}

.except {
    color: var(--theme);
    font-weight: 400;
    font-size: 28rpx;
}

.action {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
}

.action-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #fff;
    padding-left: 32rpx;
    padding-right: 32rpx;
    border-top: 1px solid #F6F7FA;
    padding-bottom: constant(safe-area-inset-bottom); /*兼容 IOS<11.2*/
    padding-bottom: env(safe-area-inset-bottom); /*兼容 IOS>11.2*/
}

.phone-btn {
    position: absolute;
    width: 630rpx;
    height: 100%;
    top: 0;
    right: 0;
    z-index: 999;
}

.action .left {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 300rpx;
}

.action .group {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #7B7B7B;
    font-size: 24rpx;
    margin-right: 24rpx;
}

.no-btn {
    margin: 0;
    padding: 0;
    background-color: inherit;
    position: static;
    flex-shrink: 0;
    line-height: normal;
}
.no-btn:after {
    content: none;
}
/* 去掉边框 */
.no-btn::after {
    border: none;
}

.group .icon {
    width: 60rpx;
    height: 60rpx;
}

.action .right {
    display: flex;
    width: 360rpx;
    padding: 10rpx 0rpx;
}

.modal-container {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    justify-content: center;
    align-items: center;
}

.modal-container .backdrop {
    position: fixed;
    width: 100%;
    height: 100%;
    z-index: 1050;
    background-color: #000;
    opacity: .5;
}

.modal {
    position: relative;
    z-index: 2020;
    background-color: #fff;
    border-radius: 40rpx;
    width: 640rpx;
}

.modal-header {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100rpx;
    font-size: 36rpx;
}

.modal-body {
    padding: 0 50rpx;
}

.modal-footer {
    position: relative;
    bottom: -102rpx;
    display: flex;
    justify-content: center;
}

.modal-footer .close {
    width: 60rpx;
    height: 60rpx;
}

.menu-btn {
    width: 100% !important;
    height: 152rpx;
    display: flex;
    align-items: center;
    background-color: #fff;
    font-size: 30rpx;
    color: #181818;
}

.menu-btn::after {
    border: none;
}

.menu-btn .icon {
    width: 100rpx;
    height: 100rpx;
    margin-right: 34rpx;
}

.menu-btn:nth-child(2) {
    border-top: 1px solid #E1E2E6;
    /* border-bottom: 1px solid #E1E2E6; */
}

.help {
    display: flex;
    width: 400rpx;
}

.help > image {
    width: 40rpx;
    height: 40rpx;
    margin-right: 8rpx;
}

.btn-container {
    margin-top: 20rpx;
    display: flex;
    justify-content: center;
}

.btn-primary {
    width: 160rpx;
    height: 50rpx;
    background-color: #5ED5C8;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24rpx;
    color: #fff;
    border-radius: 10rpx;
}

.help-container {
    display: flex;
    align-items: center;
    position: relative;
}

.help-title {
    font-size: 32rpx;
    font-weight: bold;
    color: var(--theme);
}

.help-value {
    font-size: 32rpx;
    font-weight: bold;
}

.help-info {
    position: absolute;
    top: 0;
    right: 0;
    background-color: var(--theme);
    color: white;
    padding: 4rpx 8rpx;
    font-size: 24rpx;
    border-radius: 8rpx;
}

.login-container {
    padding: 54rpx 32rpx 64rpx;
}

.login-tips {
    color: #333;
    font-weight: bold;
    font-size: 50rpx;
    margin-bottom: 54rpx;
}

.tips-title {
    line-height: 70rpx;
}

.tips-desc {
    font-size: 30rpx;
    font-weight: 400;
    line-height: 40rpx;
    color: #FF952D;
    margin-top: 12rpx;
}

.login-action {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.login-btn {
    width: 100%;
    height: 90rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    margin-bottom: 32rpx;
    border-radius: 64rpx;
    background-color: var(--theme);
    color: #fff;
}

.login-btn::after {
    border: 0;
}

.login-cancel {
    font-size: 30rpx;
    font-weight: 400;
    color: #80808B;
}

.tips-title {
    display: flex;
    justify-content: space-between;
}

.open-privacy {
    font-size: 24rpx;
    color: #279EFF;
}

.download-link {
  font-size: 32rpx;
  color: #1989fa;
}