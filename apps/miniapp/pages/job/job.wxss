.container {
    background-color: #fff;
    min-height: 100vh;
}

.swiper-container {
    margin-top: 30rpx;
    bottom: 8rpx;
    position: relative;
}

.swiper-wrapper {
    width: 100%;
    height: 280rpx;
}

.swiper-item {
    width: 650rpx !important;
    border-radius: 20rpx;
    display: flex;
    justify-content: center;
}

.swiper-image-container {
    width: 100%;
    height: 100%;
    padding-left: 18rpx;
    padding-right: 18rpx;
}

.swiper-image {
    border-radius: 20rpx;
}

.swiper-dots {
    position: relative;
    bottom: -28rpx;
    margin-bottom: 28rpx;
    display: flex;
    justify-content: center;
}

.dot-item {
    margin: 0 14rpx;
    width: 16rpx;
    height: 16rpx;
    background-color: #D1D1D1;
    border-radius: 8rpx;
    transition: all .5s;
}

.dot-item.active {
    background: #5ED5C8;
}

.search-wrapper {
    position: sticky;
    padding: 16rpx 32rpx;
    background-color: #fff;
}

.search-container {
    width: 686rpx;
    height: 80rpx;
    background-color: #f6f7fa;
    border-radius: 10rpx;
    display: flex;
    align-items: center;
}

.search-icon {
    width: 40rpx;
    height: 40rpx;
    margin-left: 28rpx;
    margin-right: 48rpx;
}

.search-input {
    width: 482rpx;
    font-size: 28rpx;
    font-weight: 400;
    color: #B5B5B5;
}

.close-icon {
    width: 32rpx;
    height: 100%;
    padding-left: 28rpx;
    padding-right: 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99;
}

.close-icon > image {
    width: 32rpx;
    height: 32rpx;
}

.list-filter {
    position: sticky;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    border-bottom: 1px solid #f6f7fa;
    background-color: #fff;
    padding: 0 32rpx;
} 

.filter-item {
    height: 80rpx;
    width: 250rpx;
    flex: auto;
    display: flex;
    justify-content: center;
    align-items: center;
}

.filter-text {
    color: #7B7B7B;
    font-size: 30rpx;
    font-weight: 400;
    margin-right: 10rpx;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.filter-icon {
    width: 30rpx;
    height: 30rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.list-wrapper {
    background-color: #F6F7FA;
}

.list-item {
    padding: 32rpx;
    background-color: #fff;
}

.item-title {
    height: 50rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14rpx;
}

.item-title .left {
    display: flex;
    align-items: center;
}

.item-title .left .text {
    font-size: 36rpx;
    color: #181818;
    line-height: 50rpx;
    max-width: 460rpx;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.item-title .left .top {
    width: 40rpx;
    height: 40rpx;
    margin-left: 4px;
}

.item-title .right {
    font-size: 24rpx;
    font-weight: 400;
    color: #acacac;
}

.item-desc {
    font-size: 26rpx;
    font-weight: 400;
    color: #7B7B7B;
    line-height: 36rpx;
    margin-bottom: 10rpx;
}

.item-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.item-footer .location {
    width: 40rpx;
    height: 40rpx;
}

.item-footer .left {
    color: #acacac;
    font-size: 28rpx;
}

.item-footer .left .text + .text {
    margin-left: 10rpx;
}

.item-footer .right {
    font-size: 30rpx;
    color: #248379;
    font-weight: bold;
}

.item-footer .right .symbol {
    margin-left: 10rpx;
    margin-right: 10rpx;
}

.item-footer .left,
.item-footer .right {
    display: flex;
    align-items: center;
}

.list-item + .list-item {
    margin-top: 10rpx;
}

.job {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.job .left {
    font-size: 36rpx;
    color: #181818;
    line-height: 56rpx;
    margin-top: 10rpx;
    font-weight: 600;
}

.job .right {
    font-size: 28rpx;
    color: #666;
}

.job-info {
    margin-top: 24rpx;
}

.info-group {
    display: flex;
    align-items: flex-start;
    line-height: 40rpx;
}

.info-group .label {
    color: #80808B;
    font-size: 28rpx;
    width: 140rpx;
    flex-shrink: 0;
}

.info-group .value {
    color: #181818;
    font-size: 28rpx;
}

.text {
    color: #181818;
    font-size: 28rpx;
    line-height: 50rpx;
    margin-top: 24rpx;
}

.job-user {
    font-weight: 400;
    font-size: 24rpx;
    color: #80808B;
    line-height: 40rpx;
    margin-top: 14rpx;
}

.job-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20rpx;
}

.date {
    font-size: 22rpx;
    font-weight: 400;
    color: #ACACAC;
}

.except,
.job-footer .symbol {
    color: #248379;
    font-weight: bold;
    font-size: 28rpx;
}

.job-footer .symbol {
    margin-left: 8rpx;
    margin-right: 8rpx;
}

.menu {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60rpx;
    padding: 0 32rpx;
}

.menu .label {
    color: #7B7B7B;
    font-size: 26rpx;
    font-weight: 400;
}

.menu .arrow {
    display: flex;
    align-items: center;
}

.arrow .label {
    color: #1989fa;
    font-size: 28rpx;
    margin-right: 12rpx;
}

.login-container {
    padding: 54rpx 32rpx 64rpx;
}

.login-tips {
    color: #333;
    font-weight: bold;
    font-size: 50rpx;
    margin-bottom: 54rpx;
}

.tips-title {
    line-height: 70rpx;
}

.tips-desc {
    font-size: 30rpx;
    font-weight: 400;
    line-height: 40rpx;
    color: #FF952D;
    margin-top: 12rpx;
}

.login-action {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.login-btn {
    width: 100%;
    height: 90rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    margin-bottom: 32rpx;
    border-radius: 64rpx;
    background-color: var(--theme);
    color: #fff;
}

.login-btn::after {
    border: 0;
}

.login-cancel {
    font-size: 30rpx;
    font-weight: 400;
    color: #80808B;
}

.tips-title {
    display: flex;
    justify-content: space-between;
}

.open-privacy {
    font-size: 24rpx;
    color: #279EFF;
}