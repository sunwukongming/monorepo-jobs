.container {
    background-color: #F6F7FA;
    min-height: 100vh;
}
.search-wrapper {
    background-color: #5ED5C8;
    padding: 16rpx 0;
}
.search-container {
    margin: 0 32rpx;
    width: 686;
    height: 80rpx;
    background-color: #fff;
    border-radius: 10rpx;
    display: flex;
    align-items: center;
}

.search-icon {
    width: 40rpx;
    height: 40rpx;
    margin-left: 28rpx;
    margin-right: 48rpx;
}

.search-input {
    width: 482rpx;
    font-size: 28rpx;
    font-weight: 400;
    color: #B5B5B5;
}

.close-icon {
    width: 32rpx;
    height: 100%;
    padding: 0 28rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99;
}

.close-icon > image {
    width: 32rpx;
    height: 32rpx;
}

.list-wrapper {
    background-color: #F6F7FA;
}

.list-item {
    padding: 32rpx;
    background-color: #fff;
}

.item-title {
    height: 50rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14rpx;
}

.item-title .left {
    display: flex;
    align-items: center;
}

.item-title .left .text {
    font-size: 36rpx;
    color: #181818;
    line-height: 50rpx;
}

.item-title .left .top {
    width: 40rpx;
    height: 40rpx;
    margin-left: 4px;
}

.item-title .right {
    font-size: 24rpx;
    font-weight: 400;
    color: #acacac;
}

.item-desc {
    font-size: 26rpx;
    font-weight: 400;
    color: #7B7B7B;
    line-height: 36rpx;
    margin-bottom: 10rpx;
}

.item-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.item-footer .location {
    width: 40rpx;
    height: 40rpx;
}

.item-footer .left {
    color: #acacac;
    font-size: 28rpx;
}

.item-footer .left .text + .text {
    margin-left: 10rpx;
}

.item-footer .right {
    font-size: 30rpx;
    color: #248379;
    font-weight: bold;
}

.item-footer .right .symbol {
    margin-left: 10rpx;
    margin-right: 10rpx;
}

.item-footer .left,
.item-footer .right {
    display: flex;
    align-items: center;
}

.list-item + .list-item {
    margin-top: 10rpx;
}

.job-info {
    margin-top: 24rpx;
    margin-bottom: 24rpx;
}

.info-group {
    display: flex;
    align-items: center;
    line-height: 40rpx;
}

.info-group .label {
    color: #80808B;
    font-size: 28rpx;
}

.info-group .value {
    color: #181818;
    font-size: 28rpx;
}