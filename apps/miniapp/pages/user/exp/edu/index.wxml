<view class="container">
    <navbar title="奖聘" showBackBtn="1"></navbar>

    <view class="bg">
        <image src="/assets/images/bg.png" mode="aspectFill"/>
    </view>
    <view class="panel">
        <view class="panel-header">
            <view class="panel-title">{{action == 'add' ? '添加' : '编辑'}}教育经历</view>
        </view>
        <view class="panel-body">
            <view class="group">
                <view class="label">学校名称</view>
                <view class="value">
                    <input class="value-text" type="text" placeholder="请输入学校名称" value="{{form.name}}" data-name="name" placeholder-class="placeholder" bindinput="changeValue"/>
                </view>
            </view>

            <view class="group" bindtap="showPopupDegree">
                <view class="label">学历</view>
                <view class="value">
                    <view class="value-text">{{form.degree}}</view>
                    <view class="icon">
                        <van-icon name="/assets/icons/arrow-right.png" size="36rpx"></van-icon>
                    </view>
                </view>
            </view>
            
            <view class="group">
                <view class="label">专业</view>
                <view class="value">
                    <input class="value-text" type="text" placeholder="请输入专业" value="{{form.profession}}" data-name="profession" placeholder-class="placeholder" bindinput="changeValue"/>
                </view>
            </view>

            <view class="group">
                <view class="label">时间段</view>
                <view class="value">
                    <view class="value-text time start" bindtap="showPopupStartTime">{{form.startTime}}</view>
                    <view class=""> - </view>
                    <view class="value-text time end" bindtap="showPopupEndTime">{{form.endTime}}</view>
                </view>
            </view>

            <view class="group">
                <view class="label">在校经历（选填）</view>
                <view class="value">
                    <input class="value-text" type="text" placeholder="请输入在校经历" value="{{form.experience}}" data-name="experience" placeholder-class="placeholder" bindinput="changeValue"/>
                </view>
            </view>

        </view>
    </view>
</view>

<view class="operation-container">
    <view class="btn btn-del" bindtap="del">{{action == 'add' ? '取消' : '删除'}}</view>
    <view class="btn btn-save" bindtap="submit">保存</view>
</view>

<popup 
    show="{{popup.degree}}" 
    position="bottom" 
>
    <van-picker
    show-toolbar
    columns="{{['专科', '本科', '研究生', '博士']}}"
    default-index="{{ 1 }}"
    bind:confirm="confirmPopupDegree"
    bind:cancel="closePopupDegree"
    />
</popup>

<popup 
    show="{{ popup.startTime }}" 
    position="bottom" 
>
    <van-datetime-picker
        type="year-month"
        value="{{ maxDate }}"
        min-date="{{ minDate }}"
        bind:cancel="closePopupStartTime"
        bind:confirm="confirmPopupStartTime"
    />
</popup>

<popup 
    show="{{ popup.endTime }}" 
    position="bottom" 
>
    <van-datetime-picker
        type="year-month"
        value="{{ maxDate }}"
        min-date="{{ minDate }}"
        bind:cancel="closePopupEndTime"
        bind:confirm="confirmPopupEndTime"
    />
</popup>
