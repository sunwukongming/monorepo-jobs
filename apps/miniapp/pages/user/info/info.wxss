.container {
    min-height: 100vh;
    background-color: #F6F7FA;
    padding-bottom: calc(110rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

.bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 750rpx;
    height: 660rpx;
}

.panel {
    position: relative;
    width: 686rpx;
    box-sizing: border-box;
    border-radius: 20rpx;
    background: #FFFFFF;
    padding: 36rpx;
    margin: 32rpx auto;
}

.panel-header {
    padding-bottom: 32rpx;
    margin-bottom: 24rpx;
}

.panel-title {
    color: #181818;
    font-size: 40rpx;
    font-weight: 600;
    line-height: 56rpx;
}

.group {
    padding: 30rpx 0;
}

.group + .group {
    border-top: 1px solid #E4E5E8;
}

.group .label {
    font-size: 24rpx;
    color: #666;
    font-weight: 400;
    line-height: 32rpx;
    margin-bottom: 22rpx;
}

.group .value {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.value input {
    width: 100%;
}

.group .value-text {
    color: #222;
    font-size: 28rpx;
    line-height: 40rpx;
    font-weight: 500;
}

.operation-container {
    box-sizing: border-box;
    width: 750rpx;
    height: 110rpx;
    position: fixed;
    bottom: constant(safe-area-inset-bottom);
    bottom: env(safe-area-inset-bottom);
    left: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 40rpx;
    background-color: #fff;
    border-top: 1px solid #E4E5E8;
    z-index: 99;
}

.btn {
    width: 320rpx;
    height: 80rpx;
    background-color: #F6F7FA;
    color: #999;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    border-radius: 56rpx;
}

.btn-save {
    background-color: var(--theme);
    color: #fff;
}

.no-btn {
    padding-left: 0;
    padding-right: 0;
}