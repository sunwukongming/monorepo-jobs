.container {
    min-height: 100vh;
    background-color: #F6F7FA;
    padding-bottom: calc(110rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

.bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 750rpx;
    height: 660rpx;
}

.panel {
    position: relative;
    width: 686rpx;
    box-sizing: border-box;
    border-radius: 20rpx;
    background: #FFFFFF;
    padding: 30rpx 32rpx;
    margin: 24rpx auto;
}

.panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.panel-title {
    font-size: 24rpx;
    line-height: 32rpx;
    color: #2AAFA1;
}

.panel-body {
    font-size: 24rpx;
    color: #222;
    line-height: 38rpx;
    font-weight: 400;
}

.userinfo {
    padding: 0;
    position: relative;
    height: 500rpx;
}

.userinfo .image {
    width: 100%;
    height: 360rpx;
}

.info-detail {
    position: absolute;
    top: 300rpx;
    margin: 0;
    padding-top: 36rpx;
    padding-bottom: 24rpx;
}

.name {
    display: flex;
    align-items: flex-end;
}

.name .text {
    font-size: 40rpx;
    font-weight: 600;
    color: #181818;
    line-height: 56rpx;
    margin-right: 10rpx;
}

.info-tag {
    display: flex;
    gap: 10rpx;
    font-size: 22rpx;
    font-weight: 400;
    color: #666;
    line-height: 30rpx;
    margin-top: 10rpx;
    margin-bottom: 10rpx;
}

.info-contact {
    display: flex;
    gap: 30rpx;
}

.contact {
    display: flex;
    align-items: center;
    color: #666;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 30rpx;
}

.form {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.form .text {
    color: #222;
    font-size: 28rpx;
    font-weight: 400;
    line-height: 40rpx;
}

.target,
.work,
.edu {
    padding: 24rpx 0;
}

.target + .target,
.work + .work,
.edu + .edu {
    border-top: 1px solid #E4E5E8;
}

.target-title {
    margin-bottom: 10rpx;
}

.target-title,
.target-title .left {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.target-title .left {
    justify-content: flex-start;
}

.target-title .text {
    font-size: 30rpx;
    font-weight: 600;
    line-height: 42rpx;
    color: #222;
    margin-right: 12rpx;
}

.target-title .tag {
    border-radius: 12rpx;
    background-color: #FFBB5F;
    color: #fff;
    font-size: 20rpx;
    width: 60rpx;
    height: 32rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.target-group,
.work-group,
.edu-group {
    display: flex;
    align-items: center;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 30rpx;
    color: #84848F;
    gap: 40rpx;
}

.target-group + .target-group, 
.work-group + .work-group {
    margin-top: 10rpx;
}

.btn {
    width: 100%;
    height: 100rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28rpx;
    line-height: 40rpx;
    color: #999;
    font-weight: 400;
    gap: 16rpx;
    background-color: #F6F7FA;
    border: 1px solid #DEF8F6;
    border-radius: 10rpx;
    margin-top: 36rpx;
}

.work-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10rpx;
}

.work-title,
.edu .school {
    font-size: 30rpx;
    font-weight: 600;
    line-height: 42rpx;
    color: #222;
}

.work-footer {
    display: flex;
    align-items: center;
    margin-top: 24rpx;
    gap: 20rpx;
}

.work-footer .tag {
    height: 40rpx;
    padding: 0 16rpx;
    background-color: #F6F7FA;
    border-radius: 12rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #999;
    font-size: 20rpx;
    font-weight: 400;
}

.edu {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.school {
    margin-bottom: 10rpx;
}

.btn-import {
    width: 686rpx;
    margin: 0 auto;
    color: #2AAFA1;
    background-color: #fff;
}

.tag-container {
    display: flex;
    flex-wrap: wrap;
}

.tag-item {
    background-color: #F6F7FA;
    font-size: 26rpx;
    color: #181818;
    width: 120rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.tag-item + .tag-item {
    margin-left: 32rpx;
}