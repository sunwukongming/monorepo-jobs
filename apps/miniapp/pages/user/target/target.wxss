.container {
    min-height: 100vh;
    background-color: #F6F7FA;
    padding-bottom: calc(110rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

.bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 750rpx;
    height: 660rpx;
}

.panel {
    position: relative;
    /* top: 144rpx; */
    width: 686rpx;
    box-sizing: border-box;
    border-radius: 20rpx;
    background: #FFFFFF;
    padding: 36rpx;
    margin: 32rpx auto;
}

.panel-header {
    padding-bottom: 32rpx;
    margin-bottom: 24rpx;
    border-bottom: 1px solid #E4E5E8;
}

.panel-title {
    color: #181818;
    font-size: 40rpx;
    font-weight: 600;
    height: 56rpx;
}

.panel-subtitle {
    color: #80808B;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 30rpx;
    margin-top: 6rpx;
}

.group {
    padding: 30rpx 0;
}

.group + .group {
    border-top: 1px solid #E4E5E8;
}

.group .label {
    font-size: 26rpx;
    color: #666;
    font-weight: 400;
    line-height: 32rpx;
    margin-bottom: 22rpx;
}

.group .value {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.group .value-text {
    color: #222;
    font-size: 28rpx;
    line-height: 40rpx;
    font-weight: 500;
    width: 550rpx;
}

.operation-container {
    box-sizing: border-box;
    width: 750rpx;
    height: 110rpx;
    position: fixed;
    bottom: constant(safe-area-inset-bottom);
    bottom: env(safe-area-inset-bottom);
    left: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 40rpx;
    background-color: #fff;
    border-top: 1px solid #E4E5E8;
    z-index: 99;
}

.btn {
    width: 320rpx;
    height: 80rpx;
    background-color: #F6F7FA;
    color: #999;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    border-radius: 56rpx;
}

.btn-save {
    background-color: var(--theme);
    color: #fff;
}

.popup-checkbox {
    height: 616rpx;
    overflow: hidden;
}

.popup-toolbar {
    display: flex;
    height: 88rpx;
    justify-content: space-between;
    line-height: 88rpx;
}

.popup-cancel,
.popup-confirm {
    color: #969799;
    font-size: 28rpx;
    padding: 0 32rpx;
}

.popup-confirm {
    color: #576b95;
}

.popup-body {
    box-sizing: border-box;
    padding: 32rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 500rpx;
    overflow: scroll;
}

.checkbox-group {
    height: 100%;
}

.checkbox, .tips {
    margin-bottom: 16rpx;
    margin-left: 32rpx;
    margin-right: 32rpx;
}

.tips {
    font-size: 28rpx;
    color: #666;
}

.help-container {
    display: flex;
    align-items: center;
}

.label-help {
    margin-left: 8rpx;
}

.label-help > image {
    width: 32rpx;
    height: 32rpx;
    position: relative;
    top: 8rpx;
}

.panel-title {
    display: flex;
    align-items: flex-end;
}

.title-second {
    font-size: 24rpx;
    color: #999;
}