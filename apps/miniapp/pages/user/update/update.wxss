.container {
    background-color: #F6F7FA;
}
.banner {
    margin-bottom: 30rpx;
    width: 750rpx;
    height: 420rpx;
    border-radius: 50%;
}

.wrapper {
    width: 686rpx;
    margin-left: 32rpx;
    margin-right: 32rpx;
    background-color: #fff;
    border-radius: 20rpx;
}

.wrapper-title {
    padding: 32rpx 0rpx 2rpx 40rpx;
    color: #29AFA1;
    font-size: 28rpx;
    font-weight: 600;
}

.wrapper + .wrapper {
    margin-top: 30rpx;
}

.form-group {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-right: 30rpx;
}

.form-group .left {
    display: flex;
    align-items: center;
    margin-top: 34rpx;
    margin-bottom: 34rpx;
}

.form-group .symbol {
    margin-left: 16rpx;
    margin-right: 12rpx;
    width: 14rpx;
    min-height: 1px;
    color: #51C1B4;
    line-height: 42rpx;
}

.form-group .label {
    font-size: 30rpx;
    font-weight: 400;
    color: #80808B;
    line-height: 42rpx;
}

.form-group .right {
    display: flex;
    align-items: center;
}

.icon {
    width: 40rpx;
    height: 40rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.form-group .input {
    text-align: right;
    color: #181818;
    font-size: 30rpx;
}

.form-group .avatar {
    width: 110rpx;
    height: 110rpx;
    margin-top: 20rpx;
    margin-bottom: 20rpx;
    border-radius: 50%;
    overflow: hidden;
}

.introduct,
.tag {
    box-sizing: border-box;
}

.tag {
    padding: 32rpx 40rpx;
}

.tag .label {
    margin-bottom: 32rpx;
}

.introduct textarea {
    margin: 32rpx 40rpx;
    min-height: 180rpx;
}

.statistics {
    text-align: right;
    font-size: 24rpx;
    font-weight: 400;
    color: #80808B;
    line-height: 32rpx;
    margin-top: 24rpx;
}

.tag-container {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
}

.tag-item {
    background-color: #F6F7FA;
    font-size: 26rpx;
    color: #181818;
    width: 120rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.tag-item .close {
    position: absolute;
    top: -12rpx;
    right: -12rpx;
    width: 24rpx;
    height: 24rpx;
    background-color: red;
    border-radius: 50%;
}

.tag-item + .tag-item {
    margin-left: 32rpx;
}

.plus {
    width: 40rpx;
    height: 40rpx;
}

.tag {
    margin-bottom: 30rpx;
}

.readme {
    margin-left: 32rpx;
    margin-bottom: 30rpx;
}

.checkbox {
    display: flex;
}

.readme .text {
    display: flex;
    align-items: center;
    color: #80808B;
    font-size: 24rpx;
}

.text .important {
    color: #2D62FF;
}

.action {
    width: 750rpx;
    height: 110rpx;
    background-color: #fff;
    padding: 10rpx 32rpx;
    box-sizing: border-box;
}

.line-container {
    width: 100%;
    display: flex;
    justify-content: flex-end;
}
.line {
    width: 650rpx;
    height: 1px;
    background-color: #E4E5E8;
}

.popup-checkbox {
    height: 616rpx;
    overflow: hidden;
}

.popup-toolbar {
    display: flex;
    height: 88rpx;
    justify-content: space-between;
    line-height: 88rpx;
}

.popup-cancel,
.popup-confirm {
    color: #969799;
    font-size: 28rpx;
    padding: 0 32rpx;
}

.popup-confirm {
    color: #576b95;
}

.popup-body {
    padding: 32rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 500rpx;
    overflow: scroll;
}

.checkbox {
    margin-bottom: 16rpx;
}
