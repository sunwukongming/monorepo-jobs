.container {
    background-color: #F6F7FA;
    min-height: 100vh;
    padding-top: 32rpx;
    padding-bottom: 64rpx;
}

.bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 750rpx;
    height: 660rpx;
}

.userinfo {
    height: 316rpx;
}

.base-info {
    display: flex;
    align-items: center;
    margin-bottom: 40rpx;
}

.avatar {
    margin-right: 20rpx;
}

.name .nickname {
    color: #181818;
    font-size: 36rpx;
    font-weight: 600;
}

.name .tips {
    display: flex;
    align-items: center;
    color: #80808B;
    font-size: 22rpx;
    line-height: 30rpx;
    margin-top: 8rpx;
}

.panel {
    position: relative;
    margin: 0 auto;
    width: 686rpx;
    box-sizing: border-box;
    border-radius: 20rpx;
    background: #FFFFFF;
    padding: 24rpx 32rpx;
}

.panel + .panel {
    margin-top: 24rpx;
}

.panel-header {
    margin-bottom: 24rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.panel-header .panel-title {
    color: #181818;
    font-size: 32rpx;
    font-weight: 600;
    height: 45rpx;
    display: flex;
    justify-content: flex-start;
    align-items: flex-end;
}

.package {
    display: flex;
    align-items: center;
}

.package .item {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.package .item .number {
    color: #666;
    font-size: 34rpx;
    line-height: 54rpx;
    font-weight: 600;
}

.package .item:first-child .number {
    color: #E9973B;
}

.package .item .label {
    color: #80808B;
    font-weight: 400;
    line-height: 30rpx;
    font-size: 22rpx;
    margin-top: 12rpx;
}

.menu {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.menu .label {
    color: #666;
    font-size: 26rpx;
}

.target {
    padding: 22rpx 0;
}

.target-title {
    margin-bottom: 22rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.target-title .left {
    display: flex;
    align-items: center;
}

.target-title .text {
    font-size: 30rpx;
    color: #666;
    font-weight: 600;
    margin-right: 28rpx;
}

.target-title .tag {
    width: 60rpx;
    height: 32rpx;
    text-align: center;
    color: #fff;
    font-size: 20rpx;
    line-height: 30rpx;
    background-color: #FFBB5F;
    border-radius: 12rpx;
    font-weight: 400;
}

.target .group {
    color: #84848F;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 30rpx;
    display: flex;
    align-items: center;
}

.group + .group {
    margin-top: 10rpx;
}

.target + .target {
    border-top: 1px solid #E4E5E8;
}

.divider {
    margin-top: 64rpx;
    padding-right: 32rpx;
    padding-left: 32rpx;
}

.function-container {
    display: flex;
    align-items: center;
}

.function {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.function .text {
    margin-top: 16rpx;
    color: #181818;
    font-size: 24rpx;
    font-weight: 400;
    line-height: 32rpx;
}

.modal-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.qrcode {
    width: 400rpx;
    height: 400rpx;
    margin-bottom: 32rpx;
}

.modal-content .tips {
    font-size: 28rpx;
    color: #80808B;
}


.login-container {
    padding: 54rpx 32rpx 64rpx;
}

.login-tips {
    color: #333;
    font-weight: bold;
    font-size: 50rpx;
    margin-bottom: 54rpx;
}

.tips-title {
    line-height: 70rpx;
}

.tips-desc {
    font-size: 30rpx;
    font-weight: 400;
    line-height: 40rpx;
    color: #FF952D;
    margin-top: 12rpx;
}

.login-action {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.login-btn {
    width: 100%;
    height: 90rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    margin-bottom: 32rpx;
    border-radius: 50rpx;
    background-color: var(--theme);
    color: #fff;
}

.login-btn::after {
    border: 0;
}

.login-cancel {
    font-size: 30rpx;
    font-weight: 400;
    color: #80808B;
}

.tips-title {
    display: flex;
    justify-content: space-between;
}

.open-privacy {
    font-size: 24rpx;
    color: #279EFF;
}

.title-second {
    font-size: 24rpx;
    color: #999;
}

.title-help > image {
    width: 32rpx;
    height: 32rpx;
    position: relative;
    top: 8rpx;
}